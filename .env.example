# 企业微信配置
SENDKEY=set_a_sendkey
WECOM_CID=your_corp_id
WECOM_SECRET=your_secret
WECOM_AID=your_agent_id
WECOM_TOUID=@all
WECOM_TOKEN=your_token
WECOM_ENCODING_AES_KEY=your_aes_key

# Komari 配置
KOMARI_URL=https://your-komari.example.com
KOMARI_USERNAME=admin
KOMARI_PASSWORD=your_password
# 或者使用 API Key (推荐)
# KOMARI_API_KEY=your_api_key

# Telegram 配置 (可选)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_API_BASE=https://api.telegram.org

# 缓存配置 (可选)
CACHE_TYPE=none
